<?xml version="1.0"?>
<Container version="2">
  <Name>ShopApp1</Name>
  <Repository>shopapp1:latest</Repository>
  <Registry></Registry>
  <Network>bridge</Network>
  <MyIP></MyIP>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/m4440473/shopapp1/issues</Support>
  <Project>https://github.com/m4440473/shopapp1</Project>
  <Overview>ShopApp1 is a shop operations app for orders, parts, checklist workflows, quotes, and time tracking. This template assumes the image is available on the Unraid host as shopapp1:latest. It defaults to SQLite stored under /mnt/user/appdata/shopapp1/db and persistent uploads under /mnt/user/appdata/shopapp1/uploads, but you can point DATABASE_URL to MySQL if desired.</Overview>
  <WebUI>http://[IP]:[PORT:3000]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/m4440473/shopapp1/main/unraid/my-shopapp1.xml</TemplateURL>
  <Icon></Icon>
  <ExtraParams></ExtraParams>
  <Config Name="WebUI" Target="3000" Default="3000" Mode="tcp" Description="Web UI" Type="Port" Display="always" Required="true" Mask="false"/>
  <Config Name="Uploads Path" Target="/app/storage" Default="/mnt/user/appdata/shopapp1/uploads" Mode="rw" Description="Persistent attachments/uploads" Type="Path" Display="always" Required="true" Mask="false"/>
  <Config Name="SQLite DB Path" Target="/app/data" Default="/mnt/user/appdata/shopapp1/db" Mode="rw" Description="SQLite database directory (used when DATABASE_URL is file:/app/data/...)" Type="Path" Display="advanced" Required="true" Mask="false"/>
  <Config Name="APP_BASE_URL" Target="APP_BASE_URL" Default="http://[IP]:[PORT:3000]" Mode="" Description="Base URL for the application" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="NEXTAUTH_URL" Target="NEXTAUTH_URL" Default="http://[IP]:[PORT:3000]" Mode="" Description="NextAuth callback URL" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="NEXT_PUBLIC_BASE_URL" Target="NEXT_PUBLIC_BASE_URL" Default="http://[IP]:[PORT:3000]" Mode="" Description="Public base URL for client usage" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="NEXTAUTH_SECRET" Target="NEXTAUTH_SECRET" Default="" Mode="" Description="Random secret for NextAuth (32+ chars)" Type="Variable" Display="always" Required="true" Mask="true"/>
  <Config Name="DATABASE_URL" Target="DATABASE_URL" Default="file:/app/data/shopapp1.db" Mode="" Description="Prisma database URL (SQLite default). For MySQL: mysql://user:pass@host:3306/db" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="ATTACHMENTS_DIR" Target="ATTACHMENTS_DIR" Default="/app/storage" Mode="" Description="Attachments root path" Type="Variable" Display="advanced" Required="true" Mask="false"/>
  <Config Name="OPENAI_API_KEY" Target="OPENAI_API_KEY" Default="" Mode="" Description="Optional. Required only if you want the Print Analyzer / BOM AI feature." Type="Variable" Display="advanced" Required="false" Mask="true"/>
</Container>
